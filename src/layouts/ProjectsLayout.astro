---
import ThemeToggle from '../components/ThemeToggle.astro';
import KeyboardHelp from '../components/KeyboardHelp.astro';
import SiteSwitcher from '../components/SiteSwitcher.astro';
import KubeConBanner from '../components/KubeConBanner.astro';
import InfoBox from '../components/InfoBox.astro';
import { getActiveBanners } from '../lib/banners';

interface Props {
  title?: string;
  stats?: {
    total: number;
    graduated: number;
    incubating: number;
    sandbox: number;
    archived: number;
  };
}

const { title = 'Indie Cloud Native — Projects', stats } = Astro.props;
const base = import.meta.env.BASE_URL;
const banners = await getActiveBanners();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Discover CNCF cloud native projects — graduated, incubating, sandbox, and archived." />
  <link rel="alternate" type="application/rss+xml" title="CNCF Projects Feed" href={`${base}/feed.xml`} />
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <div class="header-brand">
        <img src={`${base}/cncf-icon-color.svg`} alt="CNCF" class="site-logo logo-light" width="36" height="36" />
        <img src={`${base}/cncf-icon-white.svg`} alt="CNCF" class="site-logo logo-dark" width="36" height="36" />
        <div class="site-title-group">
          <h1>Indie Cloud Native</h1>
          <p class="site-subtitle" id="rotating-slogan" aria-live="polite">Built for the love of the game</p>
        </div>
        <SiteSwitcher activeSite="projects" />
      </div>
      <div class="header-controls">
        <input type="text" id="search-input" class="search-input" placeholder="Search projects..." aria-label="Search projects" />
        <ThemeToggle />
        <button id="help-button" class="icon-button" aria-label="Keyboard shortcuts (?)" title="Keyboard shortcuts (?)">?</button>
      </div>
    </div>
  </header>

  <nav class="tab-nav" aria-label="Project maturity tabs">
    <ul class="tab-list">
      <li><button class="tab-button active" data-tab="everyone">Everyone</button></li>
      <li><button class="tab-button" data-tab="graduated">Graduated</button></li>
      <li><button class="tab-button" data-tab="incubating">Incubating</button></li>
      <li><button class="tab-button" data-tab="sandbox">Sandbox</button></li>
      <li><button class="tab-button" data-tab="archived">Archived</button></li>
    </ul>
  </nav>

  <main class="main-content">
    <div class="content-area">
      <slot />
    </div>
    <aside class="sidebar">
      {stats && (
        <div class="stats-box">
          <h2 class="sidebar-heading">Projects</h2>
          <div class="stat-row"><span class="stat-label">Total CNCF</span><span class="stat-value">{stats.total}</span></div>
          <div class="stat-row stat-graduated"><span class="stat-label">Graduated</span><span class="stat-value">{stats.graduated}</span></div>
          <div class="stat-row stat-incubating"><span class="stat-label">Incubating</span><span class="stat-value">{stats.incubating}</span></div>
          <div class="stat-row stat-sandbox"><span class="stat-label">Sandbox</span><span class="stat-value">{stats.sandbox}</span></div>
          <div class="stat-row stat-archived"><span class="stat-label">Archived</span><span class="stat-value">{stats.archived}</span></div>
        </div>
      )}
      <InfoBox
        title="About"
        description="CNCF projects powering cloud native infrastructure worldwide."
        links={[
          { text: "RSS Feed", url: `${base}/feed.xml`, rss: true },
          { text: "CNCF Landscape", url: "https://landscape.cncf.io", external: true },
          { text: "People Site", url: "https://castrojo.github.io/people-website/", external: true },
        ]}
      />
      {banners.length > 0 && <KubeConBanner banners={banners} />}
    </aside>
  </main>

  <footer>
    <p>Data from <a href="https://landscape.cncf.io" target="_blank" rel="noopener">landscape.cncf.io</a> — updated daily. Indie Cloud Native — Built for the love of the game.</p>
  </footer>

  <KeyboardHelp />
</body>
</html>

<script>
  const SLOGANS = [
    "Built for the love of the game",
    "Welcome to indie cloud native",
    "Built for the love of the game. Welcome to indie cloud native",
    "Discover the CNCF cloud native ecosystem",
    "Community-driven, community-powered",
  ];
  const slogan = document.getElementById('rotating-slogan');
  if (slogan) {
    let idx = 0;
    setInterval(() => {
      slogan.classList.add('fade');
      setTimeout(() => {
        idx = (idx + 1) % SLOGANS.length;
        slogan.textContent = SLOGANS[idx];
        slogan.classList.remove('fade');
      }, 600);
    }, 12000);
  }
</script>
<style>
  #rotating-slogan { transition: opacity 0.6s ease; }
  #rotating-slogan.fade { opacity: 0; }
</style>

<style>
  @import '../styles/variables.css';
  @import '../styles/layout.css';

  .logo-light { display: block; }
  .logo-dark  { display: none; }
  [data-theme="dark"] .logo-light { display: none; }
  [data-theme="dark"] .logo-dark  { display: block; }

  .icon-button {
    background: none;
    border: 1px solid var(--color-border-default);
    border-radius: 6px;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .stats-box {
    background: var(--color-bg-default);
    border: 1px solid var(--color-border-default);
    border-radius: 6px;
    padding: 1.25rem;
  }

  .sidebar-heading {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border-default);
  }

  .stat-row {
    display: flex;
    justify-content: space-between;
    padding: 0.375rem 0;
    font-size: 0.875rem;
  }

  .stat-label { color: var(--color-text-secondary); }
  .stat-value { font-weight: 600; }
  .stat-graduated .stat-value { color: var(--color-graduated, #FFB300); }
  .stat-incubating .stat-value { color: var(--color-incubating, #0086FF); }
  .stat-sandbox .stat-value { color: var(--color-sandbox, #8b949e); }
  .stat-archived .stat-value { color: var(--color-archived, #6b7280); }
</style>
