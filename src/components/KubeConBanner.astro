---
// KubeCon Event Banner component
// Displays upcoming CNCF events with theme-aware banner images
//
// Uses official CNCF banner system with:
// - 500x500px square format
// - Light and dark theme variants via CSS class-swap (NOT prefers-color-scheme —
//   the site uses JS-driven [data-theme="dark"] on <html>, not the OS media query)
// - Auto-rotation across all banners when multiple are present

import type { BannerConfig } from '../lib/banners';

interface Props {
  banners: BannerConfig[];
}

const { banners } = Astro.props;

if (banners.length === 0) return;
---

<div class="kubecon-banner" id="kubecon-banner">
  {banners.map((banner, i) => (
    <a
      href={banner.link}
      target="_blank"
      rel="noopener noreferrer"
      class:list={['banner-slide', { active: i === 0 }]}
      aria-label={banner.name}
      data-index={i}
    >
      <!-- light mode -->
      <img
        src={banner.lightImage}
        alt={`${banner.name} banner`}
        class="banner-image logo-light"
        loading="lazy"
      />
      <!-- dark mode -->
      <img
        src={banner.darkImage}
        alt={`${banner.name} banner`}
        class="banner-image logo-dark"
        loading="lazy"
      />
    </a>
  ))}
</div>

{banners.length > 1 && (
  <script define:vars={{ totalBanners: banners.length }}>
    (function () {
      let current = 0;
      const INTERVAL_MS = 8000;

      function rotate() {
        const slides = document.querySelectorAll('#kubecon-banner .banner-slide');
        if (!slides.length) return;
        slides[current].classList.remove('active');
        current = (current + 1) % totalBanners;
        slides[current].classList.add('active');
      }

      document.addEventListener('DOMContentLoaded', () => {
        setInterval(rotate, INTERVAL_MS);
      });
    })();
  </script>
)}

<style>
  .kubecon-banner {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: box-shadow 0.2s ease;
    margin-bottom: 1.5rem;
  }

  .kubecon-banner:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .banner-slide {
    display: none;
    text-decoration: none;
  }

  .banner-slide.active {
    display: block;
  }

  .banner-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }

  /* Dark mode: CSS class-swap pattern (matches [data-theme="dark"] on <html>) */
  .logo-dark  { display: none; }
  [data-theme="dark"] .logo-light { display: none; }
  [data-theme="dark"] .logo-dark  { display: block; }

  @media (max-width: 768px) {
    .kubecon-banner {
      margin-bottom: 1rem;
    }
  }
</style>
