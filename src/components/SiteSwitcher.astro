---
interface Props {
  activeSite: 'people' | 'projects' | 'endusers';
}
const { activeSite } = Astro.props;

const sites = [
  { key: 'people',   label: 'People',    url: 'https://castrojo.github.io/people-website/' },
  { key: 'projects', label: 'Projects',  url: 'https://castrojo.github.io/projects-website/' },
  { key: 'endusers', label: 'End Users', url: 'https://castrojo.github.io/endusers-website/' },
];
---
<nav class="site-switcher" aria-label="Indie Cloud Native sites">
  {sites.map(site => (
    site.key === activeSite
      ? <span class="switcher-pill active">{site.label}</span>
      : <a class="switcher-pill" href={site.url}>{site.label}</a>
  ))}
</nav>

<style>
  .site-switcher {
    display: inline-flex;
    gap: 0;
    background: var(--color-bg-tertiary, #eaeef2);
    border: 1px solid var(--color-border-default, #d0d7de);
    border-radius: 8px;
    padding: 2px;
  }
  .switcher-pill {
    padding: 0.3rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary, #57606a);
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.15s ease;
  }
  .switcher-pill.active {
    color: #ffffff;
    background: #0086FF;
    box-shadow: 0 1px 3px rgba(0, 134, 255, 0.3);
    font-weight: 600;
  }
  .switcher-pill:hover:not(.active) {
    color: var(--color-text-primary, #24292f);
    background: var(--color-bg-default, #ffffff);
  }
</style>
<script>
  // Patch pill URLs for localhost dev navigation
  if (typeof window !== 'undefined' && window.location.hostname === 'localhost') {
    const LOCAL_URLS: Record<string, string> = {
      'people-website':   'http://localhost:4323/people-website/',
      'projects-website': 'http://localhost:4322/projects-website/',
      'endusers-website': 'http://localhost:4324/endusers-website/',
    };
    document.querySelectorAll<HTMLAnchorElement>('.switcher-pill[href]').forEach(a => {
      for (const [key, url] of Object.entries(LOCAL_URLS)) {
        if (a.href.includes(key)) { a.href = url; break; }
      }
    });
  }
</script>
