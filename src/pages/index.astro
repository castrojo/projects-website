---
import ProjectsLayout from '../layouts/ProjectsLayout.astro';
import { renderCard } from '../lib/project-renderer';
import type { SafeProject } from '../lib/project-renderer';
import { selectHeroSets } from '../lib/heroes';
import ProjectMaintainerCard from '../components/ProjectMaintainerCard.astro';
import type { ProjectMaintainer } from '../components/ProjectMaintainerCard.astro';
import fs from 'node:fs';

const base = import.meta.env.BASE_URL;

let projects: SafeProject[] = [];
let stats = { total: 0, graduated: 0, incubating: 0, sandbox: 0, archived: 0, totalStars: 0 };

try {
  const raw = fs.readFileSync('src/data/projects.json', 'utf-8');
  projects = JSON.parse(raw) as SafeProject[];
  stats.total = projects.filter(p => p.maturity !== 'archived').length;
  for (const p of projects) {
    const key = p.maturity as keyof typeof stats;
    if (key in stats && key !== 'totalStars') (stats as any)[key]++;
    if (p.stars) stats.totalStars += p.stars;
  }
} catch {
  console.warn('projects.json not found — run just sync first');
}

const categories = [...new Set(projects.filter(p => p.maturity !== 'archived').map(p => p.category).filter(Boolean))].sort();

const heroSets = selectHeroSets(projects);
const MATURITY_COLORS: Record<string, string> = {
  graduated: '#FFB300', incubating: '#0086FF', sandbox: '#8b949e', archived: '#6b7280',
};
const STATIC_COUNT = 30;
const activeProjects = projects.filter(p => p.maturity !== 'archived');
const firstBatch = activeProjects.slice(0, STATIC_COUNT);

function formatNumber(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
  return String(n);
}

// Fetch and parse CNCF project maintainers CSV at build time
const MATURITY_ORDER: Record<string, number> = { Graduated: 3, Incubating: 2, Sandbox: 1 };

let maintainers: ProjectMaintainer[] = [];
try {
  const res = await fetch('https://raw.githubusercontent.com/cncf/foundation/main/project-maintainers.csv');
  if (res.ok) {
    const text = await res.text();
    const lines = text.split('\n').filter(l => l.trim());
    // skip header row
    const byHandle = new Map<string, { name: string; handle: string; projects: string[]; maturityScore: number; maturity: string }>();
    for (const line of lines.slice(1)) {
      // CSV: Maturity,Project,Name,GitHub Handle,CNCFAssociated,Email
      const cols = line.split(',');
      if (cols.length < 4) continue;
      const maturity = cols[0]?.trim() ?? '';
      const project = cols[1]?.trim() ?? '';
      const name = cols[2]?.trim() ?? '';
      const handle = cols[3]?.trim().replace(/^@/, '') ?? '';
      // never expose email (cols[5])
      if (!handle || !name) continue;
      const score = MATURITY_ORDER[maturity] ?? 0;
      if (!byHandle.has(handle)) {
        byHandle.set(handle, { name, handle, projects: [], maturityScore: score, maturity });
      }
      const entry = byHandle.get(handle)!;
      if (project && !entry.projects.includes(project)) entry.projects.push(project);
      if (score > entry.maturityScore) {
        entry.maturityScore = score;
        entry.maturity = maturity;
      }
    }
    maintainers = [...byHandle.values()]
      .sort((a, b) => a.name.localeCompare(b.name))
      .slice(0, 30)
      .map(m => ({
        name: m.name,
        handle: m.handle,
        projects: m.projects,
        maturity: m.maturity,
        avatarUrl: `https://avatars.githubusercontent.com/${m.handle}?s=128`,
      }));
  }
} catch {
  // network unavailable at build time — CI will have access
}
---
<ProjectsLayout stats={stats} categories={categories}>
  <section class="heroes-section">
    {(Object.entries(heroSets) as [string, SafeProject[]][]).map(([tabKey, heroes]) => (
      <div class="heroes-grid" data-heroes-tab={tabKey} style={tabKey !== 'everyone' ? 'display:none' : ''}>
        {heroes.map(p => {
          const color = MATURITY_COLORS[p.maturity] ?? '#8b949e';
          const label = p.maturity.charAt(0).toUpperCase() + p.maturity.slice(1);
          return (
            <div class="hero-card" style={`--hero-color:${color}`} data-slug={p.slug}>
              <span class="hero-label">{label}</span>
              {p.logoUrl && (
                <div class="hero-logo-wrap">
                  <img src={p.logoUrl} alt={`${p.name} logo`} width="96" height="96" loading="lazy"
                    style="width:96px;height:96px;object-fit:contain;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.25))" />
                </div>
              )}
              <div class="hero-info">
                <a class="hero-name" href={p.homepageUrl || p.repoUrl || '#'} target="_blank" rel="noopener">{p.name}</a>
                <span class="hero-category">{p.category}</span>
                {(p.stars || p.contributors) && (
                  <div class="hero-stats">
                    {p.stars && <span>{formatNumber(p.stars)} stars</span>}
                    {p.contributors && <span>{formatNumber(p.contributors)} contrib</span>}
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    ))}
  </section>

  <section class="maintainers-section">
    <h2 class="section-heading">Project Maintainers</h2>
    <div class="maintainers-scroll">
      {maintainers.map(m => <ProjectMaintainerCard maintainer={m} />)}
    </div>
  </section>

  {projects.length === 0 && (
    <div class="empty-state">
      <p>No project data found. Run <code>just sync</code> to fetch data from the CNCF landscape.</p>
    </div>
  )}

  <div id="cards-container" class="cards-list" data-tab="everyone">
    <Fragment set:html={firstBatch.map(renderCard).join('')} />
  </div>

  <div id="archived-container" style="display:none"></div>
  <div id="no-results" class="empty-state" style="display:none">No projects match your search.</div>
</ProjectsLayout>

<script>
  import type { SafeProject } from '../lib/project-renderer';
  import { renderCard } from '../lib/project-renderer';
  import { renderTimeline } from '../lib/archived-timeline';
  import { initTabs, filterByTab, type TabId } from '../lib/tabs';
  import { initSearch, searchProjects } from '../lib/search';
  import { initKeyboard, tabFromNumber } from '../lib/keyboard';
  import { fireFountain, preloadOnHover, fireHearts } from '../lib/confetti';

  const base = import.meta.env.BASE_URL;
  let allProjects: SafeProject[] = [];
  let currentQuery = '';
  let currentTab: TabId = 'everyone';
  let currentCategory = '';
  let archivedRendered = false;

  async function loadProjects(): Promise<void> {
    const res = await fetch(`${base}/data/projects.json`);
    if (!res.ok) return;
    allProjects = await res.json();
    initSearch(allProjects);
  }

  function renderCurrentView(): void {
    const container = document.getElementById('cards-container')!;
    const archivedContainer = document.getElementById('archived-container')!;
    const noResults = document.getElementById('no-results')!;

    if (currentTab === 'archived') {
      container.style.display = 'none';
      archivedContainer.style.display = 'block';
      if (!archivedRendered) {
        const archived = allProjects.filter(p => p.maturity === 'archived');
        archivedContainer.innerHTML = renderTimeline(archived);
        archivedRendered = true;
      }
      return;
    }

    container.style.display = '';
    archivedContainer.style.display = 'none';

    let projects = filterByTab(allProjects, currentTab);
    if (currentCategory) {
      projects = projects.filter(p => p.category === currentCategory);
    }
    if (currentQuery) {
      const results = searchProjects(currentQuery);
      const slugs = new Set(results.map(r => r.slug));
      projects = projects.filter(p => slugs.has(p.slug));
    }

    const hasResults = projects.length > 0;
    noResults.style.display = hasResults ? 'none' : 'block';
    container.innerHTML = hasResults ? projects.map(renderCard).join('') : '';
    const countEl = document.getElementById('search-count');
    if (countEl) {
      countEl.textContent = currentQuery ? String(projects.length) : '';
    }
    wireCardEvents();
  }

  function wireCardEvents(): void {
    document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
      preloadOnHover(card);
      card.addEventListener('click', () => fireFountain(card));
    });
    document.querySelectorAll<HTMLElement>('.hero-card').forEach(card => {
      preloadOnHover(card);
      card.addEventListener('click', () => fireHearts(card));
    });
  }

  // Card focus via CSS class (matches people-website approach)
  const visibleCards = () =>
    Array.from(document.querySelectorAll<HTMLElement>('.project-card, .hero-card'))
      .filter(c => c.offsetParent !== null && c.style.display !== 'none');

  let focusedIdx = -1;

  function resetFocus() {
    document.querySelectorAll('.keyboard-focused')
      .forEach(c => c.classList.remove('keyboard-focused'));
    focusedIdx = -1;
  }

  function focusCard(idx: number) {
    const all = visibleCards();
    if (all.length === 0) return;
    focusedIdx = Math.max(0, Math.min(idx, all.length - 1));
    all.forEach((c, i) => c.classList.toggle('keyboard-focused', i === focusedIdx));
    all[focusedIdx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    const liveRegion = document.getElementById('kbd-live-region');
    if (liveRegion) {
      const name = all[focusedIdx].querySelector('.card-name, .project-name, h3, h4')?.textContent ?? '';
      liveRegion.textContent = `Focused: ${name}`;
    }
  }

  loadProjects().then(() => renderCurrentView());

  function showHeroesForTab(tab: string) {
    const heroKey = ['graduated','incubating','sandbox'].includes(tab) ? tab : 'everyone';
    document.querySelectorAll<HTMLElement>('.heroes-grid[data-heroes-tab]').forEach(grid => {
      grid.style.display = grid.dataset.heroesTab === heroKey ? 'grid' : 'none';
    });
  }

  initTabs((tab) => {
    currentTab = tab;
    showHeroesForTab(tab);
    renderCurrentView();
  });

  // Reset focus on tab change
  document.querySelectorAll('.section-link[data-tab]').forEach(btn => {
    btn.addEventListener('click', resetFocus);
  });

  document.getElementById('category-filter')?.addEventListener('change', (e) => {
    currentCategory = (e.target as HTMLSelectElement).value;
    renderCurrentView();
  });

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  searchInput?.addEventListener('input', () => {
    currentQuery = searchInput.value;
    renderCurrentView();
  });

  initKeyboard({
    searchInput,
    onSearch: () => searchInput?.focus(),
    onHelp: () => {
      document.getElementById('keyboard-help-modal')?.classList.add('visible');
      document.getElementById('keyboard-help-backdrop')?.classList.add('visible');
    },
    onTheme: () => {
      document.getElementById('theme-toggle')?.click();
      const liveRegion = document.getElementById('kbd-live-region');
      if (liveRegion) liveRegion.textContent = 'Theme toggled';
    },
    onTab: (n) => {
      const tab = tabFromNumber(n);
      document.querySelector<HTMLElement>(`.section-link[data-tab="${tab}"]`)?.click();
    },
    onEscape: () => {
      searchInput.value = '';
      currentQuery = '';
      renderCurrentView();
      document.getElementById('keyboard-help-modal')?.classList.remove('visible');
      document.getElementById('keyboard-help-backdrop')?.classList.remove('visible');
    },
    onNext: () => focusCard(focusedIdx + 1),
    onPrev: () => focusCard(focusedIdx - 1),
    onScrollTop: () => window.scrollTo({ top: 0, behavior: 'smooth' }),
    onPageDown: () => window.scrollBy({ top: window.innerHeight * 0.85, behavior: 'smooth' }),
    onPageUp: () => window.scrollBy({ top: -window.innerHeight * 0.85, behavior: 'smooth' }),
    onTabCycle: (reverse) => {
      const tabBtns = Array.from(document.querySelectorAll<HTMLElement>('.section-link[data-tab]'));
      if (tabBtns.length === 0) return;
      const activeBtn = tabBtns.find(b => b.classList.contains('active'));
      const cur = activeBtn ? tabBtns.indexOf(activeBtn) : 0;
      const next = reverse
        ? (cur - 1 + tabBtns.length) % tabBtns.length
        : (cur + 1) % tabBtns.length;
      tabBtns[next].click();
      tabBtns[next].scrollIntoView({ inline: 'nearest', block: 'nearest' });
    },
    onOpen: () => {
      const all = visibleCards();
      const card = all[focusedIdx];
      const link = card?.querySelector<HTMLAnchorElement>('a[href]');
      if (link) { window.open(link.href, '_blank', 'noopener'); return true; }
      return false;
    },
    onResetFocus: resetFocus,
  });

  document.getElementById('help-button')?.addEventListener('click', () => {
    document.getElementById('keyboard-help-modal')?.classList.add('visible');
    document.getElementById('keyboard-help-backdrop')?.classList.add('visible');
  });

  wireCardEvents();
</script>

<style is:global>
  @import '../styles/cards.css';

  .heroes-section {
    margin-bottom: 1.5rem;
  }

  .heroes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .hero-card {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    background: linear-gradient(135deg, color-mix(in srgb, var(--hero-color) 18%, transparent), color-mix(in srgb, var(--hero-color) 6%, transparent));
    border: 1px solid var(--color-border-default);
    border-top: 4px solid var(--hero-color, #0086FF);
    border-radius: 8px;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    text-align: center;
  }
  .hero-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }
  .hero-label {
    align-self: flex-start;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--hero-color);
    color: #fff;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
  }
  .hero-logo-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 0;
  }
  .hero-info {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .hero-name {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text-primary);
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hero-name:hover { text-decoration: underline; }
  .hero-category {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hero-stats {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    font-size: 0.7rem;
    color: var(--color-text-secondary);
  }

  .project-card.keyboard-focused,
  .hero-card.keyboard-focused {
    outline: 2px solid var(--color-accent-emphasis);
    outline-offset: 2px;
  }
</style>
